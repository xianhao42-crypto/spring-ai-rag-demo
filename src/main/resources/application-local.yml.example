# 复制为 application-local.yml 后按需修改

spring:
  ai:
    ollama:
      base-url: http://localhost:11434
      chat:
        options:
          model: qwen2.5-coder:7b
      embedding:
        options:
          model: bge-m3
  datasource:
    # 本机 Docker: jdbc:postgresql://localhost:5432/postgres
    # 或云服务器 / SSH 隧道地址
    url: jdbc:postgresql://localhost:5432/postgres
    username: postgres
    password: postgres
